# ===========================================
# Supabase → faqat DATABASE_URL (postgres), HTTPS URL emas
# ===========================================
# Dashboard: Project Settings → Database → Connection string → URI
# "Transaction pooler" yoki "Session pooler" tavsiya etiladi (Prisma uchun).
# Parolni shu yerda "Database password" dan olasiz (yoki reset qilasiz).
#
# Misol shakli (O‘ZINGIZNIKI bilan almashtiring):
# DATABASE_URL="postgresql://postgres.pzhmouigcbdyhbkzbgxr:[YOUR-PASSWORD]@aws-0-XXXX.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# Yoki "Direct connection" — migratsiya uchun ba’zan qulay:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.pzhmouigcbdyhbkzbgxr.supabase.co:5432/postgres"

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres"

# ===========================================
# Clerk (kirish / hisob)
# ===========================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ===========================================
# Ilova URL (SSR da tRPC uchun, prod’da majburiy deb hisoblang)
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3008

# ===========================================
# Clerk Billing — Pro rejangiz id boshqacha bo‘lsa
# ===========================================
# NEXT_PUBLIC_CLERK_PRO_PLAN_ID=user:pro

# ===========================================
# Agent / fon vazifalar (loyihadagi AI ishlashi uchun)
# ===========================================
# Inngest: https://app.inngest.com → sync qilishda ko‘rsatiladi
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# E2B sandboxes
# E2B_API_KEY=

# Google Gemini (@inngest/agent-kit gemini())
# GOOGLE_GENERATIVE_AI_API_KEY=
# yoki GOOGLE_API_KEY=  — SDK versiyasiga qarab
