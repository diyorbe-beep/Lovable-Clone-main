# ===========================================
# 1) Nusxa:  Copy-Item .env.example .env.local
# 2) .env.local ichida __REPLACE_WITH_SUPABASE_DB_PASSWORD__ ni haqiqiy parol bilan almashtiring
# ===========================================
#
# --- FAQAT SIZ (GitHub / Vercel dashboard) ---
# - GitHub → Settings → Developer settings → OAuth Apps: yangi app, Callback URL:
#   {NEXT_PUBLIC_APP_URL}/api/oauth/github/callback
# - Vercel (ixtiyoriy): Project → Settings → Git → Deploy Hooks → URL ni oling
#
# --- WINDOWS: `npx prisma generate` EPERM (DLL rename) ---
# Dev server / boshqa jarayon `query_engine-windows.dll` ni ushlab turgan bo‘lishi mumkin.
# `npm run dev` ni to‘xtating, keyin qayta urining; yoki antivirus istisno qiling.
# ===========================================

# Supabase → Settings → Database → URI (postgres://...)
# TAYYOR QATOR (faqat parolni qo'ying):
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk → Webhooks → Add endpoint URL: {NEXT_PUBLIC_APP_URL}/api/webhooks/clerk
# Subscribe to: user.created, user.updated, user.deleted — paste Signing secret here:
# CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_BILLING_ENABLED=0

NEXT_PUBLIC_APP_URL=http://localhost:3008

# GitHub OAuth (Ship → Connect GitHub). Callback URL:
# {NEXT_PUBLIC_APP_URL}/api/oauth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# Min 32 characters; used to encrypt stored GitHub tokens
# INTEGRATION_ENCRYPTION_KEY=

# Optional: override default Gemini model for the code agent
# AGENT_GEMINI_MODEL=gemini-2.0-flash

# Code agent: optional API keys (need at least one LLM provider + E2B + Inngest)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Force provider: gemini | openai | anthropic (optional; otherwise inferred from keys)
# CODE_AGENT_PROVIDER=
# Default model id for that provider (optional)
# CODE_AGENT_MODEL=

# Chat “UI screenshot” uses vision on the same keys; if the chosen model lacks vision,
# the worker falls back to Gemini (Google key) or GPT-4o mini / Claude Haiku when set.

# Optional: Vercel deploy hook URL (Project → Settings → Git → Deploy Hooks)
# VERCEL_DEPLOY_HOOK_URL=

# Optional: Vercel API — list deployments and pick READY URL after hook (Team ID = slug or team_… from dashboard)
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=

# Optional: stable production URL (used when sandbox URLs expire and as API fallback)
# VERCEL_PRODUCTION_URL=https://your-app.vercel.app

# Optional: long-lived preview URL (CDN / Vercel production) when sandbox URLs expire
# HOSTED_FALLBACK_PREVIEW_URL=

# Optional: same Supabase project as DATABASE_URL — exposed to generated apps (client-safe URL)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# NEXT_PUBLIC_CLERK_PRO_PLAN_ID=user:pro

# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
# INNGEST_DEV=1
# E2B_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# FREE_POINTS_LIMIT=3
# PRO_POINTS_LIMIT=100
# GENERATION_COST=1
# USAGE_WINDOW_DAYS=30
# MAX_ACTIVE_RUNS_PER_USER=1
