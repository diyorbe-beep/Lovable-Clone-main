# ===========================================
# 1) Nusxa:  Copy-Item .env.example .env.local
# 2) .env.local ichida __REPLACE_WITH_SUPABASE_DB_PASSWORD__ ni haqiqiy parol bilan almashtiring
# ===========================================

# Supabase → Settings → Database → URI (postgres://...)
# TAYYOR QATOR (faqat parolni qo'ying):
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_BILLING_ENABLED=0

NEXT_PUBLIC_APP_URL=http://localhost:3008

# NEXT_PUBLIC_CLERK_PRO_PLAN_ID=user:pro

# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
# INNGEST_DEV=1
# E2B_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# FREE_POINTS_LIMIT=3
# PRO_POINTS_LIMIT=100
