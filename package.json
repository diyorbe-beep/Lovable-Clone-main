{
  "name": "lovable-clone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3008",
    "dev:worker": "inngest-cli dev -u http://localhost:3008/api/inngest",
    "dev:all": "concurrently -n app,worker -c cyan,magenta \"npm:dev\" \"npm:dev:worker\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:prompt-smoke": "tsx scripts/prompt-regression-smoke.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e .env.local -- prisma migrate dev",
    "db:push": "dotenv -e .env.local -- prisma db push"
  },
